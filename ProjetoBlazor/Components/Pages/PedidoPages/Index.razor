@page "/Pedido"
@rendermode InteractiveServer
@inject Utils.Relatorios RelatoriosUtil

<PageTitle>Pedidos</PageTitle>

<div class="container-fluid">
    <h3>Pedidos</h3>

    <div class="card mb-3">
        <div class="card-body">
            <div class="input-group">
                <span class="input-group-text">Filtrar por Cliente:</span>
                <input type="text" class="form-control" @bind="filtroNome" @bind:event="oninput" placeholder="Digite para buscar..." />
                <button class="btn btn-outline-secondary" @onclick="LimparFiltro">Limpar</button>
            </div>
        </div>
    </div>

    <div class="mb-3 d-flex gap-2">
        <button class="btn btn-success" @onclick="Novo">
            <i class="bi bi-plus-circle"></i> Novo
        </button>

        <button class="btn btn-primary" disabled="@(pedidoSelecionado == null)" @onclick="Alterar">
            <i class="bi bi-pencil"></i> Alterar
        </button>

        <button class="btn btn-danger" disabled="@(pedidoSelecionado == null)" @onclick="Excluir">
            <i class="bi bi-trash"></i> Excluir
        </button>

        <button class="btn btn-info" @onclick="Visualizar" disabled="@(pedidoSelecionado == null)">
            <i class="bi bi-printer"></i> Imprimir Pedido
        </button>
    </div>

    @if (pedidos == null)
    {
        <div class="alert alert-info">Carregando dados...</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th># Pedido</th>
                        <th>Cod</th>
                        <th>Cliente</th>
                        <th class="text-center">Data</th>
                        <th class="text-end">Valor Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in pedidosFiltrados)
                    {
                        <tr @onclick="() => SelecionarLinha(item)"
                            style="cursor: pointer;"
                            class="@(pedidoSelecionado?.Codigo == item.Codigo ? "table-primary" : "")">

                            @* 1. Código com preenchimento de zeros*@
                            <td class="fw-bold">@item.Codigo.ToString("D4")</td>

                            @* 2. Código Cliente *@
                            <td> @item.ClienteCodigo</td>

                            @* 3. Nome Cliente *@
                            <td>@item.ClienteNome</td>

                            @* 4. Data formatada para o padrão brasileiro *@
                            <td class="text-center">@item.Data.ToString("dd/MM/yyyy")</td>

                            @* 5. Valor total formatado como Moeda *@
                            <td class="text-end fw-bold text-primary">
                                @((item.ValorTotal ?? 0).ToString("C2"))
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (carregando)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" style="display: flex; align-items: center; justify-content: center;">
        <div class="text-center text-white">
            <div class="spinner-border" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <h5 class="mt-3">Gerando Visualização...</h5>
        </div>
    </div>
}

@code {
    private List<Pedido>? pedidos;
    private Pedido? pedidoSelecionado;
    private string filtroNome = "";
    private bool carregando = false;

    // Lógica do Filtro: sempre que o filtro muda, a lista filtrada se ajusta
    private IEnumerable<Pedido> pedidosFiltrados =>
        pedidos?.Where(x => string.IsNullOrWhiteSpace(filtroNome) ||
        x.Codigo.ToString().Contains(filtroNome, StringComparison.OrdinalIgnoreCase))

        ?? Enumerable.Empty<Pedido>();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        // Fazemos um Join simples para trazer o nome do cliente sem precisar alterar a Model
        var query = from p in context.Pedido
                    join c in context.Cliente on p.ClienteCodigo equals c.Codigo
                    select new { p, NomeCliente = c.Nome };

        var resultado = await query.ToListAsync();

        // Vamos mapear para uma lista temporária ou usar um DTO.
        // Para facilitar sua vida agora, vamos usar a propriedade 'Descricao' (ou outra string solta)
        // do objeto Pedido para guardar o nome temporariamente na tela:
        pedidos = resultado.Select(x =>
        {
            x.p.ClienteNome = x.NomeCliente;
            return x.p;
        }).ToList();
    }

    private void SelecionarLinha(Pedido pd)
    {
        // Se clicar no que já está selecionado, desmarca
        if (pedidoSelecionado?.Codigo == pd.Codigo)
            pedidoSelecionado = null;
        else
            pedidoSelecionado = pd;
    }

    private void LimparFiltro() => filtroNome = "";

    private void Novo()
    {
        Nav.NavigateTo("/Pedido/Form/0");
    }

    private void Alterar()
    {
        if (pedidoSelecionado != null)
        {
            Nav.NavigateTo("/Pedido/Form/" + pedidoSelecionado.Controle);
        }
    }

    private async void Excluir()
    {
        if (pedidoSelecionado != null)
        {
            // 1. Pergunta ao usuário usando o confirm do navegador
            bool confirmado = await JS.InvokeAsync<bool>("confirm", "Confirma Exclusão ?");

            if (confirmado)
            {
                try
                {
                    using var context = DbFactory.CreateDbContext();

                    // 2. Remove do banco de dados
                    context.Pedido.Remove(pedidoSelecionado);
                    await context.SaveChangesAsync();

                    // 3. Atualiza a lista na tela para refletir a exclusão
                    pedidos?.Remove(pedidoSelecionado);
                    pedidoSelecionado = null; // Limpa a seleção

                    // Opcional: Feedback visual
                    await JS.InvokeVoidAsync("alert", "pedido excluído com sucesso!");

                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    await JS.InvokeVoidAsync("alert", "Erro ao excluir: " + ex.Message);
                }
            }
        }
    }

    private async Task Visualizar()
    {
        try
        {
            carregando = true; // Ativa a rodinha
            StateHasChanged(); // Força o Blazor a renderizar o loading

            // Importante: Damos um pequeno delay para garantir que o navegador
            // renderize o spinner antes de começar o processamento pesado
            await Task.Delay(100);

            if (pedidoSelecionado != null)
            {
                // 1. Busca os itens do pedido no banco se ainda não estiverem carregados
                using var context = DbFactory.CreateDbContext();
                var itens = await context.PedidoItem
                                         .Where(x => x.ControlePedido == pedidoSelecionado.Controle)
                                         .ToListAsync();

                // 2. Gera os bytes do PDF
                var pdfBytes = RelatoriosUtil.GerarVisualizacaoPedidoBytes(pedidoSelecionado, itens);

                // 3. Converte para Base64 e envia para o JavaScript fazer o download
                var base64 = Convert.ToBase64String(pdfBytes);
                await JS.InvokeVoidAsync("downloadFile", $"Pedido_{pedidoSelecionado.Codigo}.pdf", base64);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erro ao gerar visualização: " + ex.Message);
        }
        finally
        {
            carregando = false; // Desativa a rodinha
            StateHasChanged(); // Atualiza a tela para remover o modal de loading
        }
    }
}