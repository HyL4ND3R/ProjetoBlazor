@page "/Pedido/Form/{Controle:int}"

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Pedido #@pedido.Codigo</h5>
        <span class="badge bg-info">Total: @pedido.ValorTotal.ToString("C2")</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <label>Data</label>
                <input type="date" class="form-control" @bind="pedido.Data" />
            </div>
            <div class="col-md-6">
                <label>Cliente</label>
                <select class="form-select" @bind="pedido.ClienteCodigo">
                    <option value="0">Selecione...</option>
                    @foreach (var c in clientes)
                    {
                        <option value="@c.Codigo">@c.Nome</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between">
        <h6>Itens do Pedido</h6>
        <button class="btn btn-sm btn-success" @onclick="() => NovoItem()">
            <i class="bi bi-plus"></i> Novo
        </button>
        <button class="btn btn-sm btn-outline-primary" disabled="@(itemSelecionado == null)" @onclick="() => AlterarItem()">
            <i class="bi bi-pencil"></i> Alterar
        </button>
        <button class="btn btn-sm btn-outline-danger" disabled="@(itemSelecionado == null)" @onclick="() => ExcluirItemPedido()">
            <i class="bi bi-trash"></i> Excluir
        </button>
    </div>
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>Item</th>
                <th>Produto</th>
                <th>Qtd</th>
                <th>Unitário</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in itens)
            {
                <tr @onclick="() => SelecionarLinha(item)"
                    style="cursor: pointer;"
                    class="@(itemSelecionado?.Controle == item.Controle ? "table-primary" : "")">
                    <td>@item.Item</td>
                    <td>@item.Descricao</td>
                    <td>@item.Quantidade</td>
                    <td>@item.ValorUn.ToString("N2")</td>
                    <td>@item.ValorTotal.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (mostrarModal)
{
    <FormItem Item="itemSelecionado" OnClose="FecharModal" OnSave="SalvarItemPedido" />
}

@code {
    [Parameter] public int Controle { get; set; }
    private Pedido pedido = new() { Data = DateTime.Now };
    private List<Cliente> clientes = new();
    private List<PedidoItem> itens = new();
    private bool mostrarModal = false;
    private PedidoItem? itemSelecionado;

    protected override async Task OnInitializedAsync()
    {
        if (Controle > 0)
        {
            pedido = DbFactory.CreateDbContext().Pedido.FirstOrDefault(p => p.Controle == Controle) ?? new Pedido();
            itens = DbFactory.CreateDbContext().PedidoItem.Where(i => i.ControlePedido == pedido.Controle).ToList();
        }
    }

    private void SelecionarLinha(PedidoItem item)
    {
        // Se clicar no que já está selecionado, desmarca
        if (itemSelecionado?.Controle == item.Controle)
            itemSelecionado = null;
        else
            itemSelecionado = item;
    }

    private void NovoItem()
    {
        itemSelecionado = new PedidoItem
        {
            ControlePedido = pedido.Controle,
            Item = itens.Count + 1
        };
        mostrarModal = true;
    }

    private void AlterarItem()
    {
        if (itemSelecionado != null)
        {
            mostrarModal = true;
        }
    }

    private async Task SalvarItemPedido(PedidoItem item)
    {
        try
        {
            if (item.Controle == 0)
            {
                var context = DbFactory.CreateDbContext();

                if (item.Controle > 0)
                {
                    // Se o código for maior que 0, é uma edição, então atualiza o objeto no banco
                    context.PedidoItem.Update(item);
                    await context.SaveChangesAsync();
                }
                else
                {
                    // Se não é uma inclusão, então adiciona o novo operador ao banco
                    context.PedidoItem.Add(item);
                    await context.SaveChangesAsync();
                }
                await context.Database.ExecuteSqlRawAsync("EXEC sp_RecalcularTotaisPedido {0}", item.ControlePedido);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erro ao salvar item: {ex.Message}");
        }
        mostrarModal = false;
    }

    private async Task ExcluirItemPedido()
    {
        try
        {
            if (itemSelecionado != null)
            {
                var context = DbFactory.CreateDbContext();
                context.PedidoItem.Remove(itemSelecionado);
                await context.SaveChangesAsync();
                await context.Database.ExecuteSqlRawAsync("EXEC sp_RecalcularItempedido {0}", itemSelecionado.ControlePedido);
                await context.Database.ExecuteSqlRawAsync("EXEC sp_RecalcularTotaisPedido {0}", itemSelecionado.ControlePedido);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Erro ao excluir item: {ex.Message}");
        }
    }

    private void FecharModal() => mostrarModal = false;
}