@page "/"
@layout LayoutDeslogado
@rendermode InteractiveServer

@if (!verificando)
{
    <div class="row justify-content-center min-vh-100 align-items-center">
        <div class="col-md-4">
            <div class="card shadow-sm" style="max-width: 400px">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">LOGIN</h4>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label">Código:</label>
                        <input type="number" class="form-control" @bind="codigoInput" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Senha</label>
                        <input type="password" class="form-control" @bind="senhaInput" @onkeyup="VerificarTecla" />
                    </div>

                    @if (!string.IsNullOrEmpty(mensagemErro))
                    {
                        <div class="alert alert-danger py-2">@mensagemErro</div>
                    }

                    <button class="btn btn-primary w-100" @onclick="ValidarLogin">
                        <i class="bi bi-box-arrow-in-right"></i> Acessar
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; display: flex; justify-content: center; align-items: center; background-color: #f8f9fa; z-index: 9999;">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>
}

@if (carregando)
{
    <div class="modal-backdrop fade show" style="z-index: 1060;"></div>

    <div style="position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        z-index: 1070;
        color: white;">
        
        <div class="spinner-border text-light" role="status" style="width: 3.5rem; height: 3.5rem;">
            <span class="visually-hidden">Carregando...</span>
        </div>
        
        <h5 class="mt-3 fw-bold" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
            Verificando Login...
        </h5>
    </div>
}

@code {
    private bool verificando = true;
    private int? codigoInput;
    private string senhaInput = "";
    private string mensagemErro = "";
    private bool carregando = false;

    protected override async Task OnInitializedAsync()
    {
        Operador? operadorLogado = await SessaoService.GetOperadorLogadoAsync();

        if (operadorLogado != null)
        {
            // Se tem alguém logado, vai pra Home
            Nav.NavigateTo("/Home", forceLoad: true);
        }
        else
        {
            // Se NÃO tem ninguém logado, libera a tela de login para ser exibida
            verificando = false;

            // Como OnInitializedAsync terminou, o Blazor vai re-renderizar a tela
            // automaticamente, caindo no 'else' do HTML lá em cima.
        }
    }

    private async Task VerificarTecla(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ValidarLogin();
    }

    private async Task ValidarLogin()
    {
        try
        {
            carregando = true; // Ativa a rodinha
            StateHasChanged(); // Força o Blazor a renderizar o loading

            // Importante: Damos um pequeno delay para garantir que o navegador
            // renderize o spinner antes de começar o processamento pesado
            await Task.Delay(100);

            using var context = DbFactory.CreateDbContext();

            var operador = await context.Operador
                .FirstOrDefaultAsync(x => x.Codigo == codigoInput && x.Senha == senhaInput && x.Inativo == 0);

            if (operador != null)
            {
                await SessionStorage.SetAsync("OperadorLogado", operador.Nome);
                Nav.NavigateTo("/Home", forceLoad: true);
            }
            else
            {
                mensagemErro = "Credenciais inválidas ou operador inativo.";
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Erro no login: {ex.Message}");
            await LogService.GravarLog(ex.Message, ex.StackTrace);
            await JS.InvokeVoidAsync("alert", "Ocorreu um erro ao tentar fazer login. Tente novamente mais tarde.");
        }
        finally
        {
            carregando = false; // Desativa a rodinha
            StateHasChanged(); // Atualiza a tela para esconder o loading
        }
    }
}