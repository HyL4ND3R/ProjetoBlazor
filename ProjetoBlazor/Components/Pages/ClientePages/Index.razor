@page "/Cliente"
@rendermode InteractiveServer

<PageTitle>Clientes</PageTitle>

<div class="container-fluid">
    <h3>Clientes</h3>

    <div class="card mb-3">
        <div class="card-body">
            <div class="input-group">
                <span class="input-group-text">Pesquisar:</span>
                <input type="text" class="form-control" @bind="filtroNome" @bind:event="oninput" placeholder="Digite para buscar..." />
                <button class="btn btn-outline-secondary" @onclick="LimparFiltro">Limpar</button>
            </div>
        </div>
    </div>

    <div class="mb-3 d-flex gap-2">

        <button class="btn btn-success" @onclick="NovoRegistro">
            <i class="bi bi-plus-circle"></i> Novo
        </button>

        <button class="btn btn-primary" disabled="@(clienteSelecionado == null)" @onclick="EditarSelecionado">
            <i class="bi bi-pencil"></i> Alterar
        </button>

        <button class="btn btn-danger" disabled="@(clienteSelecionado == null)" @onclick="ExcluirSelecionado">
            <i class="bi bi-trash"></i> Excluir
        </button>
    </div>

    @if (clientes == null)
    {
        <div class="alert alert-info">Carregando dados...</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Código</th>
                        <th>Nome</th>
                        <th>Documento</th>
                        <th>Telefone</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in ClientesFiltrados)
                    {
                        <tr @onclick="() => SelecionarLinha(item)"
                            style="cursor: pointer;"
                            class="@(clienteSelecionado?.Codigo == item.Codigo ? "table-primary" : "")">
                            <td>@item.Codigo</td>
                            <td>@item.Nome</td>
                            <td>@item.Documento</td>
                            <td>@item.Telefone</td>
                            <td>
                                <span class="badge @(item.Inativo == 1 ? "bg-danger" : "bg-success")">
                                    @(item.Inativo == 1 ? "Inativo" : "Ativo")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Cliente>? clientes;
    private Cliente? clienteSelecionado;
    private string filtroNome = "";

    // Lógica do Filtro: sempre que o filtro muda, a lista filtrada se ajusta
    private IEnumerable<Cliente> ClientesFiltrados =>
        clientes?.Where(x => string.IsNullOrWhiteSpace(filtroNome) ||
        x.Nome.Contains(filtroNome, StringComparison.OrdinalIgnoreCase) ||
        x.Codigo.ToString().Contains(filtroNome, StringComparison.OrdinalIgnoreCase))

        ?? Enumerable.Empty<Cliente>();

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        clientes = await context.Cliente.ToListAsync();
    }

    private void SelecionarLinha(Cliente cl)
    {
        // Se clicar no que já está selecionado, desmarca
        if (clienteSelecionado?.Codigo == cl.Codigo)
            clienteSelecionado = null;
        else
            clienteSelecionado = cl;
    }

    private void LimparFiltro() => filtroNome = "";

    private void NovoRegistro()
    {
        Nav.NavigateTo("/Cliente/Form");
    }

    private void EditarSelecionado()
    {
        if (clienteSelecionado != null)
        {
            Nav.NavigateTo("/Cliente/Form/" + clienteSelecionado.Codigo);
        }
    }

    private async void ExcluirSelecionado()
    {
        if (clienteSelecionado != null)
        {
            // 1. Pergunta ao usuário usando o confirm do navegador
            bool confirmado = await JS.InvokeAsync<bool>("confirm", "Confirma Exclusão ?");

            if (confirmado)
            {
                try
                {
                    using var context = DbFactory.CreateDbContext();

                    // 2. Remove do banco de dados
                    context.Cliente.Remove(clienteSelecionado);
                    await context.SaveChangesAsync();

                    // 3. Atualiza a lista na tela para refletir a exclusão
                    clientes?.Remove(clienteSelecionado);
                    clienteSelecionado = null; // Limpa a seleção

                    // Opcional: Feedback visual
                    await JS.InvokeVoidAsync("alert", "Cliente excluído com sucesso!");

                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    await JS.InvokeVoidAsync("alert", "Erro ao excluir: " + ex.Message);
                }
            }
        }
    }
}