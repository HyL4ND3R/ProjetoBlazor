@page "/Produto/Form"
@page "/Produto/Form/{id:int}"

<PageTitle>Operador</PageTitle>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(mensagemSucesso))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @mensagemSucesso
                        <button type="button" class="btn-close" @onclick="() => mensagemSucesso = null"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(mensagemErro))
                {
                    <div class="alert alert-danger" role="alert">
                        @mensagemErro
                    </div>
                }
                @if (operador.Codigo > 0)
                {
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Operador</h5>
                    </div>
                }
                else
                {
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-person-plus"></i> Cadastrar Operador</h5>
                    </div>
                }
                <div class="card-body">
                    <EditForm Model="operador" OnValidSubmit="SalvarOperador">
                        <DataAnnotationsValidator />

                        @if (operador.Codigo > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Código<span class="text-danger">*</span></label>
                                <InputNumber class="form-control" @bind-Value="operador.Codigo" required disabled />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Nome do Operador <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="operador.Nome" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Senha <span class="text-danger">*</span></label>
                            <InputText type="password" class="form-control" @bind-Value="operador.Senha" required />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="checkAdmin" @bind="isAdmin">
                                    <label class="form-check-label" for="checkAdmin">
                                        Perfil Administrador
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="checkInativo" @bind="isInativo">
                                    <label class="form-check-label text-danger" for="checkInativo">
                                        Usuário Inativo
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg"></i> Salvar
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="Voltar">
                                Cancelar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? id { get; set; }
    private Operador operador = new Operador();
    // Variáveis auxiliares para os checkboxes na tela
    private bool isAdmin = false;
    private bool isInativo = false;
    private string? mensagemSucesso;
    private string? mensagemErro;

    protected override async Task OnInitializedAsync()
    {
        if (id > 0)
        {
            operador = DbFactory.CreateDbContext().Operador.FirstOrDefault(o => o.Codigo == id) ?? new Operador();
        }
    }

    private async Task SalvarOperador()
    {
        try
        {
            // Converte os booleanos da tela para os bytes do banco (1 ou 0)
            operador.Admin = isAdmin ? (byte)1 : (byte)0;
            operador.Inativo = isInativo ? (byte)1 : (byte)0;
            var context = DbFactory.CreateDbContext();

            if (operador.Codigo > 0)
            {
                // Se o código for maior que 0, é uma edição, então atualiza o objeto no banco
                context.Operador.Update(operador);
                await context.SaveChangesAsync();
            }
            else
            {
                // Se não é uma inclusão, então adiciona o novo operador ao banco
                context.Operador.Add(operador);
                await context.SaveChangesAsync();
            }
            mensagemSucesso = "Operador salvo com sucesso!";

            // Se era inclusão, o EF preencheu o 'operador.Codigo' automaticamente.
            // Agora "avisamos" o Blazor que a URL mudou para modo de edição, sem recarregar a página.
            Nav.NavigateTo($"/Operador/Form/{operador.Codigo}", replace: true);

            _ = Task.Delay(5000).ContinueWith(_ =>
{
    mensagemSucesso = null;
    InvokeAsync(StateHasChanged);
});
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao salvar o operador: {ex.Message}";
            _ = Task.Delay(5000).ContinueWith(_ =>
{
    mensagemErro = null;
    InvokeAsync(StateHasChanged);
});
        }
    }

    private void Voltar()
    {
        Nav.NavigateTo("/Operador");
    }
}