@page "/Produto/Form"
@page "/Produto/Form/{id:int}"

<PageTitle>Produto</PageTitle>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(mensagemSucesso))
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @mensagemSucesso
                        <button type="button" class="btn-close" @onclick="() => mensagemSucesso = null"></button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(mensagemErro))
                {
                    <div class="alert alert-danger" role="alert">
                        @mensagemErro
                    </div>
                }
                @if (Produto.Codigo > 0)
                {
                    <div class="card-header bg-warning text-dark">
                        <h5 class="mb-0"><i class="bi bi-pencil-square"></i> Editar Produto</h5>
                    </div>
                }
                else
                {
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-person-plus"></i> Cadastrar Produto</h5>
                    </div>
                }
                <div class="card-body">
                    <EditForm Model="Produto" OnValidSubmit="SalvarProduto">
                        <DataAnnotationsValidator />

                        @if (Produto.Codigo > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Código<span class="text-danger">*</span></label>
                                <InputNumber class="form-control" @bind-Value="Produto.Codigo" required disabled />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Descrição<span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="Produto.Nome" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Valor<span class="text-danger">*</span></label>
                            <InputNumber class="form-control" @bind-Value="Produto.Valor" required />
                        </div>

                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="checkInativo" @bind="isInativo">
                                <label class="form-check-label text-danger" for="checkInativo">
                                    Inativo
                                </label>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg"></i> Salvar
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="Voltar">
                                Cancelar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public int? id { get; set; }
    private Produto Produto = new Produto();
    // Variáveis auxiliares
    private bool isInativo = false;
    private string? mensagemSucesso;
    private string? mensagemErro;

    protected override async Task OnInitializedAsync()
    {
        if (id > 0)
        {
            Produto = DbFactory.CreateDbContext().Produto.FirstOrDefault(o => o.Codigo == id) ?? new Produto();
            isInativo = Produto.Inativo == 1;
        }
    }

    private async Task SalvarProduto()
    {
        try
        {
            Produto.Inativo = isInativo ? (byte)1 : (byte)0;
            var context = DbFactory.CreateDbContext();

            if (Produto.Codigo > 0)
            {
                // Se o código for maior que 0, é uma edição, então atualiza o objeto no banco
                context.Produto.Update(Produto);
                await context.SaveChangesAsync();
            }
            else
            {
                // Se não é uma inclusão, então adiciona o novo Produto ao banco
                context.Produto.Add(Produto);
                await context.SaveChangesAsync();
            }
            mensagemSucesso = "Produto salvo com sucesso!";

            // Se era inclusão, o EF preencheu o 'Produto.Codigo' automaticamente.
            // Agora "avisamos" o Blazor que a URL mudou para modo de edição, sem recarregar a página.
            Nav.NavigateTo($"/Produto/Form/{Produto.Codigo}", replace: true);

            _ = Task.Delay(5000).ContinueWith(_ =>
{
    mensagemSucesso = null;
    InvokeAsync(StateHasChanged);
});
        }
        catch (Exception ex)
        {
            mensagemErro = $"Erro ao salvar o Produto: {ex.Message}";
            _ = Task.Delay(5000).ContinueWith(_ =>
{
    mensagemErro = null;
    InvokeAsync(StateHasChanged);
});
        }
    }

    private void Voltar()
    {
        Nav.NavigateTo("/Produto");
    }
}